@gateway = http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE IN VISUAL STUDIO
#   1. Click the green ▶ "Send Request" button that appears above each ###
#   2. Run ### Register once (skip if already done)
#   3. Run ### Login — the JWT token is captured automatically, no copy-paste
#   4. Every protected request below picks it up via {{login.response.body.$.token}}
# ─────────────────────────────────────────────────────────────────────────────


# ── Auth ─────────────────────────────────────────────────────────────────────

### Register Admin directly (or seed data handles it)
POST {{gateway}}/api/auth/register
Content-Type: application/json

{
  "email": "ipek@bambicim.com",
  "password": "Test1234!",
  "firstName": "İpek",
  "lastName": "Bayrak"
}

### Login  ← run this before any 🔒 request
# @name login
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "email": "ipek@bambicim.com",
  "password": "Test1234!"
}

### Get my profile  🔒
GET {{gateway}}/api/auth/me
Authorization: Bearer {{login.response.body.$.token}}

### Change a user's role  🔒 Admin only
PATCH {{gateway}}/api/auth/2/role
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "role": "Admin"
}


# ── Categories ───────────────────────────────────────────────────────────────

### List all categories  🔒 (Gateway policy restricts this currently)
GET {{gateway}}/api/categories
Authorization: Bearer {{login.response.body.$.token}}

### Get single category  🔒
GET {{gateway}}/api/categories/1
Authorization: Bearer {{login.response.body.$.token}}

### Create category  🔒 Admin only
POST {{gateway}}/api/categories
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "name": "New Footwear",
  "slug": "new-footwear"
}

### Update category  🔒 Admin only
PUT {{gateway}}/api/categories/1
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "name": "Updated Footwear",
  "slug": "updated-footwear",
  "isActive": true
}

### Delete category  🔒 Admin only
DELETE {{gateway}}/api/categories/1
Authorization: Bearer {{login.response.body.$.token}}


# ── Products ─────────────────────────────────────────────────────────────────

### List all products  🔒 (Gateway config currently defaults to requiring auth)
GET {{gateway}}/api/products?page=1&pageSize=10
Authorization: Bearer {{login.response.body.$.token}}

### Get single product  🔒
GET {{gateway}}/api/products/1
Authorization: Bearer {{login.response.body.$.token}}

### Create product  🔒 Admin only
POST {{gateway}}/api/products
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "name": "Smart Watch",
  "categoryId": 1,
  "price": 199.99,
  "stock": 50,
  "sku": "WATCH-100",
  "description": "Latest smart watch",
  "imageUrl": "https://example.com/watch.jpg"
}

### Update product  🔒 Admin only
PUT {{gateway}}/api/products/1
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "name": "Smart Watch Pro",
  "categoryId": 1,
  "price": 249.99,
  "stock": 40,
  "sku": "WATCH-100-PRO",
  "description": "Updated model",
  "visible": true
}

### Delete product  🔒 Admin only
DELETE {{gateway}}/api/products/1
Authorization: Bearer {{login.response.body.$.token}}


# ── Inventory ────────────────────────────────────────────────────────────────

### Decrease stock  🔒
POST {{gateway}}/api/inventory/decrease
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "items": [{ "productId": 1, "quantity": 1 }]
}


# ── Orders ───────────────────────────────────────────────────────────────────

### Get all orders  🔒
GET {{gateway}}/api/orders?page=1&pageSize=10
Authorization: Bearer {{login.response.body.$.token}}

### Get single order  🔒
GET {{gateway}}/api/orders/1
Authorization: Bearer {{login.response.body.$.token}}

### Create order  🔒
POST {{gateway}}/api/orders
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "customerEmail": "ipek@bambicim.com",
  "items": [{ "productId": 1, "quantity": 2 }]
}

### Cancel order  🔒
POST {{gateway}}/api/orders/1/cancel
Authorization: Bearer {{login.response.body.$.token}}

### Mark order as Paid  🔒 Admin only
POST {{gateway}}/api/orders/1/paid
Authorization: Bearer {{login.response.body.$.token}}

### Mark order as Shipped  🔒 Admin only
POST {{gateway}}/api/orders/1/ship
Authorization: Bearer {{login.response.body.$.token}}

### Mark order as Delivered  🔒 Admin only
POST {{gateway}}/api/orders/1/deliver
Authorization: Bearer {{login.response.body.$.token}}


# ── Payments ─────────────────────────────────────────────────────────────────

### Process payment via Gateway Orders Proxy  🔒
POST {{gateway}}/api/orders/pay
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "orderId": 1,
  "amount": 179.97,
  "currency": "usd",
  "method": "CreditCard",
  "paymentMethodId": "pm_card_visa",
  "simulateFailure": false
}

### Process direct Payment  🔒
POST {{gateway}}/api/payments/pay
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "orderId": 1,
  "amount": 179.97,
  "currency": "usd",
  "method": "CreditCard",
  "paymentMethodId": "pm_card_visa",
  "simulateFailure": false
}

### Simulate failed payment (Insufficient Funds) 🔒
POST {{gateway}}/api/payments/pay
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "orderId": 99,
  "amount": 179.97,
  "currency": "usd",
  "method": "CreditCard",
  "paymentMethodId": "pm_card_chargeDeclinedInsufficientFunds",
  "simulateFailure": false
}

### Simulate failed payment (Generic Decline) 🔒
POST {{gateway}}/api/payments/pay
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "orderId": 100,
  "amount": 179.97,
  "currency": "usd",
  "method": "CreditCard",
  "paymentMethodId": "pm_card_chargeDeclined",
  "simulateFailure": false
}


# ── Health checks ────────────────────────────────────────────────────────────

### Gateway
GET {{gateway}}/health

### UserService
GET http://localhost:5101/health

### CatalogService
GET http://localhost:5098/health

### OrderService
GET http://localhost:5099/health

### PaymentService
GET http://localhost:5100/health
