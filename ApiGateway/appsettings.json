{
  "Jwt": {
    "Secret": "super-secret-development-key-change-in-production-32chars!",
    "Issuer": "ECommercePlatform",
    "Audience": "ECommercePlatform"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "users",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "products": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "categories": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "inventory": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      "orders": {
        "ClusterId": "orders",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "payments": {
        "ClusterId": "payments",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "users": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "catalog": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5098"
          }
        }
      },
      "orders": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5099"
          }
        }
      },
      "payments": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5100"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
